{
    "[json][rust][nix][dart][lua]": {
        "coc.preferences.formatOnSave": true,
    },
    // Don't display inlay hints by default.
    // Toggle with `:CocCommand document.toggleInlayHint`
    "inlayHint.display": false,
    "workspace.ignoredFolders": [
        "$HOME",
        // rust-analyzer: don't cargo check sysroot crates.
        "$HOME/.cargo/**",
        "$HOME/.rustup/**",
        // flutter/dart: don't check pub packages.
        "$HOME/.pub-cache/**",
    ],
    // Prevent dart files from adding a new global workspace folder.
    //
    // Without this, opening a *.dart file resolves workspace root to the
    // nearest pubspec.yaml dir (e.g. public/app/). That folder is sent to
    // ALL LSPs via workspace/didChangeWorkspaceFolders. rust-analyzer then
    // walks up from it, discovers a second Cargo.toml, and loads a duplicate
    // cargo workspace (two `cargo check` processes).
    // coc-flutter still works: it resolves its own rootUri independently
    // via documentsManager.resolveRoot(["pubspec.yaml"]).
    "workspace.ignoredFiletypes": ["dart"],
    // // Does NOT fix rust-analyzer and dart lsp conflicts
    // "workspace.bottomUpFiletypes": ["dart", "yaml"],
    "Lua.format.enable": true,
    "Lua.format.defaultConfig": {
        "indent_style": "space",
        "indent_size": "4",
    },
    "Lua.misc.parameters": [
        "--metapath",
        "~/.cache/lua-language-server/meta",
        "--logpath",
        "~/.cache/lua-language-server/log",
    ],
    "Lua.diagnostics.disable": [
        "redefined-local"
    ],
    "Lua.runtime.pathStrict": true,
    "Lua.runtime.version": "LuaJIT",
    "Lua.workspace.ignoreSubmodules": true,
    "Lua.workspace.checkThirdParty": false,
    "Lua.diagnostics.libraryFiles": "Disable",
    "sumneko-lua.checkUpdate": false,
    "sumneko-lua.logPath": "${userHome}/.cache/lua-language-server/log",
    "sumneko-lua.serverDir": "${userHome}/.local/share/lua-language-server",
    // // When this is turned on, coc-sumneko-lua appears to pull in like 2
    // // extra synthetic/out-of-date vim interfaces that confuse
    // // goto_definition. Plus, everything seems to work just fine without
    // // this.
    // "sumneko-lua.enableNvimLuaDev": true,
    "rust-analyzer.checkOnSave": true,
    "rust-analyzer.diagnostics.disabled": [
        "macro-error",
        "incorrect-ident-case",
        "inactive-code",
        "unresolved-proc-macro",
    ],
    "rust-analyzer.server.path": "${userHome}/.cargo/bin/rust-analyzer",
    "rust-analyzer.updates.checkOnStartup": false,
    // // uncomment for debugging. then `:CocCommand workspace.showOutput` to
    // // view the logs.
    // "rust-analyzer.trace.server": "verbose",
    "dart.showTodos": false,
    "languageserver": {
        "go": {
            "command": "gopls",
            "filetypes": ["go"],
            "rootPatterns": ["go.work", "go.mod", ".git/"],
            "initializationOptions": {
                "usePlaceholders": true
            }
        },
        "nix": {
            "command": "nil",
            "filetypes": ["nix"],
            "rootPatterns": [".git", "flake.nix", "configuration.nix", "default.nix"],
            "settings": {
                "nil": {
                    "formatting": {
                        "command": ["nixfmt", "--width=80"]
                    },
                    "diagnostics": {
                        "excludedFiles": ["generated.nix"]
                    }
                }
            }
        },
        "python-ruff": {
            "command": "ruff",
            "args": ["server"],
            "filetypes": ["python"],
            "rootPatterns": ["ruff.toml", ".ruff.toml", "pyproject.toml", "setup.py", "setup.cfg", "requirements.txt", ".git/"],
        },
        "python-ty": {
            "command": "ty",
            "args": ["server"],
            "filetypes": ["python"],
            "rootPatterns": ["ty.toml", "pyproject.toml", "setup.py", "setup.cfg", "requirements.txt", ".git/"],
        }
    }
}
